# Copy this to scripts/ec2/.env (gitignored) and fill in your values.
#
# EC2_HOST       ssh target, e.g. ubuntu@1.2.3.4 or ec2-user@my-instance
# EC2_KEY        path to the SSH private key (PEM). Leave blank if your
#                key is loaded into ssh-agent.
# EC2_REMOTE_DIR remote working directory. Default matches the script's
#                expectation; change only if you know the layout.

EC2_HOST=ubuntu@CHANGE_ME
EC2_KEY=
EC2_REMOTE_DIR=~/zkmerkle-proof-of-solvency
