# Go binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test & coverage output
*.test
*.out

# Vendored deps (Go modules manage these; commit only if explicitly vendoring)
vendor/

# zk trusted setup & proof artifacts (very large — keygen output, e.g. zkpor50_700.pk is ~12GB)
*.pk
*.vk
*.r1cs
*.proof

# smoke harness runtime output (config.json files the smoke writes
# per-service, plus dumped final_cex_assets.json / user_config.json).
# The smoke script regenerates these from templates each run.
cmd/witness/config/config.json
cmd/prover/config/config.json
cmd/verifier/config/config.json
cmd/userproof/config/config.json
cmd/verifier/config/user_config.json
.artifacts/*.json
.artifacts/testdata/

# R11 — gen-testdata 출력 (실측용 큰 CSV — 수십 MB-GB)
# .artifacts/testdata/<profile>_<N>/ 패턴.

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local config / secrets (per-developer overrides, never commit)
.env
.env.*
!.env.example
!scripts/ec2/.env.example
*.local.json
config.local.*
scripts/ec2/.env
